# QueueEase V2 — Backend Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ─── Server Configuration ──────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database Configuration ─────────────────────────────────────
# Local MongoDB: mongodb://localhost:27017/queueease
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/queueease?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/queueease

# ─── JWT Authentication ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# ─── Firebase Admin SDK ────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# ─── ML / AI Microservice ──────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001
ML_API_KEY=queueease-dev-key-change-in-prod

# ─── CORS Configuration ────────────────────────────────────────
# Frontend origin for local dev
CORS_ORIGIN=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting (Optional) ──────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging (Optional) ────────────────────────────────────────
LOG_LEVEL=debug
